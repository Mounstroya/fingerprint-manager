            self._dev_detail_lbl.set_text('')

    # ── PAM ──────────────────────────────────────────────────

    def _update_pam_ui(self):
        enabled = is_pam_enabled()
        if enabled:
            self._pam_status_lbl.set_text('Activo')
            self._pam_status_lbl.get_style_context().remove_class('pam-inactive')
            self._pam_status_lbl.get_style_context().add_class('pam-active')
            self._pam_btn.set_label('Desactivar')
        else:
            self._pam_status_lbl.set_text('Inactivo')
            self._pam_status_lbl.get_style_context().remove_class('pam-active')
            self._pam_status_lbl.get_style_context().add_class('pam-inactive')
            self._pam_btn.set_label('Activar')

    def _on_pam_toggle(self, btn):
        enable = not is_pam_enabled()
        if enable:
            msg = ('¿Activar huella para login y sudo?\n\n'
                   'Se pedirá tu contraseña de administrador.\n'
                   'Si la huella falla, siempre podrás usar tu contraseña.')
        else:
            msg = '¿Desactivar autenticación por huella para login y sudo?'

        confirm = Gtk.MessageDialog(
            transient_for=self, modal=True,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.YES_NO,
            text='Configuración de acceso',
        )
        confirm.format_secondary_text(msg)
        resp = confirm.run()
        confirm.destroy()
        if resp != Gtk.ResponseType.YES:
            return

        self._pam_btn.set_sensitive(False)
        self._pam_btn.set_label('Aplicando...')

        ok, err = set_pam(enable)
        if not ok:
            dlg = Gtk.MessageDialog(
                transient_for=self, modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text='No se pudo cambiar la configuración'
            )
            dlg.format_secondary_text(err or 'Operación cancelada.')
            dlg.run()
            dlg.destroy()

        self._pam_btn.set_sensitive(True)
        self._update_pam_ui()

    # ── Finger list ──────────────────────────────────────────

    def _show_banner(self, msg):
        self._banner_lbl.set_text(msg)
        self._banner.show()

    def _hide_banner(self):
        self._banner.hide()

    def _get_enrolled(self):
        try:
            _, _, dev, _ = get_device()
            return [str(f) for f in dev.ListEnrolledFingers(USERNAME)]
        except dbus.DBusException:
            return []

    def _refresh(self):
        self._update_device_info()
        self._update_pam_ui()

        for child in self._listbox.get_children():
            self._listbox.remove(child)

        ok, err = check_device()
        if not ok:
            self._show_banner(err)
            self._add_btn.set_sensitive(False)
            self._test_btn.set_sensitive(False)
            self._listbox.show_all()
            return

        self._hide_banner()
        fingers = self._get_enrolled()

        if not fingers:
            empty = Gtk.Label(label='No hay huellas registradas')
            empty.get_style_context().add_class('empty-label')
            row = Gtk.ListBoxRow()
            row.set_selectable(False)
            row.set_activatable(False)
            row.add(empty)
            self._listbox.add(row)
            self._test_btn.set_sensitive(False)
        else:
            self._test_btn.set_sensitive(True)
            for f in fingers:
                self._listbox.add(self._make_row(f))

        self._add_btn.set_sensitive(len(fingers) < len(FINGER_LABELS))
        self._listbox.show_all()

    def _make_row(self, finger_key):
        name = FINGER_LABELS.get(finger_key, finger_key)
        row = Gtk.ListBoxRow()
        row.set_selectable(False)
        row.set_activatable(False)
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.set_border_width(10)

        fp_icon = Gtk.Image.new_from_icon_name('auth-fingerprint-symbolic', Gtk.IconSize.MENU)
        fp_icon.set_size_request(24, -1)
        box.pack_start(fp_icon, False, False, 0)

        name_lbl = Gtk.Label(label=name)
        name_lbl.set_xalign(0)
        box.pack_start(name_lbl, True, True, 0)

        del_btn = Gtk.Button()
        del_btn.set_relief(Gtk.ReliefStyle.NONE)
        del_btn.set_image(Gtk.Image.new_from_icon_name('edit-delete-symbolic', Gtk.IconSize.BUTTON))
        del_btn.set_tooltip_text(f'Eliminar {name}')
        del_btn.connect('clicked', self._on_delete, finger_key, name)
        box.pack_end(del_btn, False, False, 0)

        row.add(box)
        return row

    def _on_add(self, btn):
        dlg = EnrollDialog(self, self._get_enrolled())
        dlg.run()
        dlg.destroy()
        self._refresh()

    def _on_test(self, btn):
        dlg = VerifyDialog(self)
        dlg.run()
        dlg.destroy()

    def _on_delete(self, btn, finger_key, name):
        confirm = Gtk.MessageDialog(
            transient_for=self, modal=True,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.YES_NO,
            text=f'¿Eliminar "{name}"?'
        )
        confirm.format_secondary_text('Esta acción no se puede deshacer.')
        resp = confirm.run()
        confirm.destroy()
        if resp != Gtk.ResponseType.YES:
            return

        dev = None
        try:
            _, _, dev, _ = get_device()
            dev.Claim(USERNAME)
            dev.DeleteEnrolledFinger(finger_key)
        except dbus.DBusException as e:
            err = Gtk.MessageDialog(
                transient_for=self, modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text='Error al eliminar la huella'
            )
            err.format_secondary_text(e.get_dbus_message())
            err.run()
            err.destroy()
        finally:
            if dev:
                try:
                    dev.Release()
                except Exception:
                    pass
        self._refresh()


def check_runtime_deps():
    missing = []
    try:
        import dbus  # noqa
    except ImportError:
        missing.append('python3-dbus')
    try:
        import gi  # noqa
        gi.require_version('Gtk', '3.0')
        from gi.repository import Gtk  # noqa
    except Exception:
        missing.append('python3-gi gir1.2-gtk-3.0')
    if missing:
        print(f"ERROR: faltan dependencias: {', '.join(missing)}", file=sys.stderr)
        print('Instálalas con: sudo apt install ' + ' '.join(missing), file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    check_runtime_deps()
    apply_css()
    FingerprintManager()
    Gtk.main()
