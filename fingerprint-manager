        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
    )


def get_device():
    bus = dbus.SystemBus()
    mgr_obj = bus.get_object('net.reactivated.Fprint', '/net/reactivated/Fprint/Manager')
    mgr = dbus.Interface(mgr_obj, 'net.reactivated.Fprint.Manager')
    path = mgr.GetDefaultDevice()
    dev_obj = bus.get_object('net.reactivated.Fprint', path)
    dev = dbus.Interface(dev_obj, 'net.reactivated.Fprint.Device')
    props = dbus.Interface(dev_obj, 'org.freedesktop.DBus.Properties')
    return bus, dev_obj, dev, props


def check_device():
    """Returns (ok, error_message)."""
    try:
        get_device()
        return True, None
    except dbus.DBusException as e:
        msg = str(e.get_dbus_message())
        if 'no fingerprint readers' in msg.lower() or 'NoSuchObject' in str(e):
            return False, 'No se encontró ningún lector de huella.'
        if 'org.freedesktop.DBus.Error.ServiceUnknown' in str(e):
            return False, 'fprintd no está activo. Ejecuta: sudo systemctl start fprintd'
        return False, f'Error al conectar con fprintd: {msg}'


def get_device_info():
    """Returns dict with name, scan_type, num_stages or None on error."""
    try:
        _, _, _, props = get_device()
        name = str(props.Get('net.reactivated.Fprint.Device', 'name'))
        stages = int(props.Get('net.reactivated.Fprint.Device', 'num-enroll-stages'))
        scan_raw = str(props.Get('net.reactivated.Fprint.Device', 'scan-type'))
        scan = 'Presión' if scan_raw == 'press' else 'Deslizamiento'
        return {'name': name, 'stages': stages, 'scan': scan}
    except Exception:
        return None


def is_pam_enabled():
    try:
        with open(PAM_FILE) as f:
            return 'pam_fprintd' in f.read()
    except Exception:
        return False


def set_pam(enable):
    """Toggle fprintd in PAM. Returns (success, error_msg)."""
    if enable:
        cmd = 'pam-auth-update --enable fprintd'
    else:
        cmd = 'pam-auth-update --disable fprintd'
    result = subprocess.run(
        ['pkexec', 'sh', '-c', cmd],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        return False, result.stderr.strip() or 'Error desconocido'
    return True, None


class EnrollDialog(Gtk.Dialog):
    def __init__(self, parent, enrolled_fingers):
        super().__init__(title='Registrar nueva huella', transient_for=parent, modal=True)
        self.set_default_size(380, 280)
        self.set_border_width(0)

        self._bus = self._dev_obj = self._dev = None
        self._signal = None
        self._enrolling = False
        self._stages_done = 0
        self._total_stages = 20
        self._response_timeout = None
        self.enrolled_finger = None

        content = self.get_content_area()
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_border_width(20)
        content.pack_start(box, True, True, 0)

        lbl = Gtk.Label(label='Dedo a registrar:')
        lbl.set_xalign(0)
        box.pack_start(lbl, False, False, 0)

        self._combo = Gtk.ComboBoxText()
        for key, name in FINGER_LABELS.items():
            if key not in enrolled_fingers:
                self._combo.append(key, name)
        self._combo.set_active(0)
        box.pack_start(self._combo, False, False, 0)

        self._progress = Gtk.ProgressBar()
        self._progress.set_show_text(True)
        self._progress.set_text('0%')
        box.pack_start(self._progress, False, False, 4)

        self._stage_lbl = Gtk.Label()
        self._stage_lbl.set_markup('<small>0 capturas realizadas</small>')
        self._stage_lbl.set_xalign(0.5)
        box.pack_start(self._stage_lbl, False, False, 0)

        self._status_lbl = Gtk.Label(label='Selecciona un dedo y presiona Iniciar.')
        self._status_lbl.set_line_wrap(True)
        self._status_lbl.set_xalign(0.5)
        self._status_lbl.set_justify(Gtk.Justification.CENTER)
        self._status_lbl.set_size_request(-1, 40)
        box.pack_start(self._status_lbl, True, True, 0)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_halign(Gtk.Align.END)
        self._cancel_btn = Gtk.Button(label='Cancelar')
        self._cancel_btn.connect('clicked', self._on_cancel)
        self._start_btn = Gtk.Button(label='Iniciar')
        self._start_btn.get_style_context().add_class('suggested-action')
        self._start_btn.connect('clicked', self._on_start)
        btn_box.pack_start(self._cancel_btn, False, False, 0)
        btn_box.pack_start(self._start_btn, False, False, 0)
        box.pack_start(btn_box, False, False, 4)

        self.show_all()
        self.connect('delete-event', lambda *a: self._cancel_enrollment() or False)

    def _set_status(self, msg, style='info'):
        for cls in ('status-info', 'status-success', 'status-error'):
            self._status_lbl.get_style_context().remove_class(cls)
        self._status_lbl.get_style_context().add_class(f'status-{style}')
        self._status_lbl.set_text(msg)

    def _on_start(self, btn):
        finger = self._combo.get_active_id()
        if not finger:
            return
        try:
            self._bus, self._dev_obj, self._dev, props = get_device()
            self._total_stages = int(props.Get('net.reactivated.Fprint.Device', 'num-enroll-stages'))
            self._dev.Claim(USERNAME)
        except dbus.DBusException as e:
            msg = str(e.get_dbus_message())
            if 'AlreadyInUse' in str(e) or 'already' in msg.lower():
                self._set_status('El dispositivo está en uso, intenta de nuevo.', 'error')
            elif 'PermissionDenied' in str(e):
                self._set_status('Permisos insuficientes.', 'error')
            else:
                self._set_status(f'Error: {msg}', 'error')
            return

        self._enrolling = True
        self._stages_done = 0
        self._progress.set_fraction(0)
        self._progress.set_text('0%')
        self._combo.set_sensitive(False)
        self._start_btn.set_sensitive(False)
        self._set_status('Coloca tu dedo en el lector...', 'info')
        self._signal = self._dev_obj.connect_to_signal('EnrollStatus', self._on_enroll_status)
        try:
            self._dev.EnrollStart(finger)
        except dbus.DBusException as e:
            self._set_status(f'Error: {e.get_dbus_message()}', 'error')
            self._release_device()

    def _on_enroll_status(self, result, done):
        result = str(result)
        msg = ENROLL_MESSAGES.get(result, result)

        if result == 'enroll-stage-passed':
            self._stages_done += 1
            frac = min(self._stages_done / self._total_stages, 1.0)
            self._progress.set_fraction(frac)
            self._progress.set_text(f'{int(frac * 100)}%')
            plural = 'captura' if self._stages_done == 1 else 'capturas'
            self._stage_lbl.set_markup(
                f'<small>{self._stages_done} {plural} de {self._total_stages}</small>')
            self._set_status(msg, 'info')

        elif result == 'enroll-completed':
            self._progress.set_fraction(1.0)
            self._progress.set_text('100%')
            self._set_status(msg, 'success')
            self.enrolled_finger = self._combo.get_active_id()
            self._enrolling = False
            self._release_device(stop=False)
            self._start_btn.set_label('Cerrar')
            self._start_btn.set_sensitive(True)
            self._start_btn.connect('clicked', lambda *a: self.response(Gtk.ResponseType.OK))
            self._cancel_btn.set_sensitive(False)
            self._response_timeout = GLib.timeout_add(
                2000, lambda: self.response(Gtk.ResponseType.OK))

        elif result in ('enroll-failed', 'enroll-data-full', 'enroll-duplicate', 'enroll-disconnected'):
            self._set_status(msg, 'error')
            self._enrolling = False
            self._release_device()
            self._combo.set_sensitive(True)
            self._start_btn.set_sensitive(True)
        else:
            self._set_status(msg, 'info')

    def _release_device(self, stop=True):
        if self._response_timeout:
            GLib.source_remove(self._response_timeout)
            self._response_timeout = None
        if self._signal:
            self._signal.remove()
            self._signal = None
        if self._dev:
            if stop:
                try:
                    self._dev.EnrollStop()
                except Exception:
                    pass
            try:
                self._dev.Release()
            except Exception:
                pass
            self._dev = None

    def _cancel_enrollment(self):
        self._enrolling = False
        self._release_device(stop=True)

    def _on_cancel(self, btn):
        self._cancel_enrollment()
        self.response(Gtk.ResponseType.CANCEL)


class VerifyDialog(Gtk.Dialog):
    def __init__(self, parent):
        super().__init__(title='Probar huella', transient_for=parent, modal=True)
        self.set_default_size(320, 200)
        self.set_border_width(0)

        self._dev = self._dev_obj = None
        self._sig_status = self._sig_finger = None
        self._verifying = False

        content = self.get_content_area()
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        box.set_border_width(24)
        box.set_valign(Gtk.Align.CENTER)
        content.pack_start(box, True, True, 0)

        self._icon = Gtk.Image.new_from_icon_name('auth-fingerprint-symbolic', Gtk.IconSize.DIALOG)
        box.pack_start(self._icon, False, False, 0)

        self._status = Gtk.Label(label='Iniciando...')
        self._status.set_line_wrap(True)
        self._status.set_justify(Gtk.Justification.CENTER)
        box.pack_start(self._status, False, False, 0)

        self.add_button('Cerrar', Gtk.ResponseType.CLOSE)
        self.show_all()
        self.connect('delete-event', lambda *a: self._stop() or False)
        self.connect('response', lambda *a: self._stop())
        GLib.idle_add(self._start_verify)

    def _set_status(self, msg, style='info'):
        for cls in ('status-info', 'status-success', 'status-error'):
            self._status.get_style_context().remove_class(cls)
        self._status.get_style_context().add_class(f'status-{style}')
        self._status.set_text(msg)

    def _start_verify(self):
        try:
            _, self._dev_obj, self._dev, _ = get_device()
            self._dev.Claim(USERNAME)
        except dbus.DBusException as e:
            msg = str(e.get_dbus_message())
            self._set_status(
                'Dispositivo en uso, intenta de nuevo.' if 'AlreadyInUse' in str(e)
                else f'Error: {msg}', 'error')
            return

        self._verifying = True
        self._sig_status = self._dev_obj.connect_to_signal('VerifyStatus', self._on_verify_status)
        self._sig_finger = self._dev_obj.connect_to_signal('VerifyFingerSelected', self._on_finger_selected)
        try:
            self._dev.VerifyStart('any')
            self._set_status('Coloca tu dedo en el lector...', 'info')
        except dbus.DBusException as e:
            self._set_status(f'Error: {e.get_dbus_message()}', 'error')
            self._release_device()

    def _on_finger_selected(self, finger):
        pass  # Could update icon here if needed

    def _on_verify_status(self, result, done):
        result = str(result)
        msg, style = VERIFY_MESSAGES.get(result, (result, 'info'))
        self._set_status(msg, style)
        if result == 'verify-match':
            self._icon.set_from_icon_name('emblem-default-symbolic', Gtk.IconSize.DIALOG)
        elif result == 'verify-no-match':
            self._icon.set_from_icon_name('dialog-error-symbolic', Gtk.IconSize.DIALOG)
        if done:
            self._verifying = False
            if self._dev:
                try:
                    self._dev.VerifyStop()
                except Exception:
                    pass
            self._release_device()

    def _release_device(self):
        for sig in (self._sig_status, self._sig_finger):
            if sig:
                sig.remove()
        self._sig_status = self._sig_finger = None
        if self._dev:
            try:
                self._dev.Release()
            except Exception:
                pass
            self._dev = None

    def _stop(self):
        if self._verifying and self._dev:
            self._verifying = False
            try:
                self._dev.VerifyStop()
            except Exception:
                pass
        self._release_device()


